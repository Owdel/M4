public class FinanceManager {
    
 private static final String PESO = "PHP ";
 
    private FinanceManager() {}
 
    public static void printIncomeStatement() {
        List<Map<String, String>> transactions = DatabaseHelper.getAllTransactions();
 
        if (transactions.isEmpty()) {
            System.out.println("No transactions found.");
            return;
        }
 
        double totalRevenue = 0;
        double totalTax     = 0;
        double totalIncome  = 0;
 
        System.out.println("\n================================================");
        System.out.println("              INCOME STATEMENT                 ");
        System.out.println("================================================");
        System.out.printf("%-5s %-15s %-12s %-12s %-14s %-12s%n",
                "ID", "Username", "Amount", "Tax(12%)", "Total", "Date");
        System.out.println("------------------------------------------------");
 
        for (Map<String, String> t : transactions) {
            double amount = parseDouble(t.get("amount"));
            double tax    = parseDouble(t.get("tax"));
            double total  = parseDouble(t.get("totalAmount"));
 
            totalRevenue += amount;
            totalTax     += tax;
            totalIncome  += total;
 
            System.out.printf("%-5s %-15s %-12s %-12s %-14s %-12s%n",
                    t.get("id"),
                    t.get("username"),
                    PESO + String.format("%,.2f", amount),
                    PESO + String.format("%,.2f", tax),
                    PESO + String.format("%,.2f", total),
                    t.get("date"));
        }
 
        System.out.println("================================================");
        System.out.printf("  Total Revenue  : %s%,.2f%n", PESO, totalRevenue);
        System.out.printf("  Total Tax      : %s%,.2f%n", PESO, totalTax);
        System.out.printf("  Total Income   : %s%,.2f%n", PESO, totalIncome);
        System.out.println("================================================");
    }
 
    private static double parseDouble(String value) {
        try {
            return value != null ? Double.parseDouble(value) : 0.0;
        } catch (NumberFormatException e) {
            return 0.0;
        }
public class KitchenPayment extends PaymentFramework {
 
    private final int    kitchenBookingId;
    private final String username;
    private final String description;
 
    public KitchenPayment(int kitchenBookingId, String username, String description) {
        if (kitchenBookingId <= 0)
            throw new FinanceException("Invalid kitchen booking ID.", "KitchenPayment");
        if (username == null || username.isEmpty())
            throw new FinanceException("Username is required.", "KitchenPayment");
        this.kitchenBookingId = kitchenBookingId;
        this.username         = username;
        this.description      = description != null ? description : "Kitchen booking payment";
    }
 
    // ---------------------------------------------------------------
    // All 5 abstract methods implemented below
    // ---------------------------------------------------------------
 
    // Always valid — this is a billing system, not a bank
    @Override
    protected boolean validatePayment(double amount) {
        return amount > 0;
    }
 
    // All four payment methods are accepted
    @Override
    protected boolean validatePaymentMethod(PaymentMethod method) {
        return method != null;
    }
 
    // Saves the transaction to our database
    @Override
    protected void finalizeTransaction(double total, String receipt) {
        boolean saved = DatabaseHelper.insertFrameworkTransaction(
                kitchenBookingId, username, total, description, LocalDate.now().toString());
        if (!saved)
            throw new FinanceException("Failed to save transaction to database.", "KitchenPayment");
    }
 
    // Marks the kitchen booking as Paid after payment
    @Override
    protected void onTransactionComplete(String receipt) {
        DatabaseHelper.updateKitchenAvailability(kitchenBookingId, "Paid");
    }
 
