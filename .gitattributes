public class Reservation {
    
private final String username;
    private final String itemName;
    private final double amount;
    private final String date;
    private String status;
 
    private Reservation(Builder builder) {
        this.username = builder.username;
        this.itemName = builder.itemName;
        this.amount   = builder.amount;
        this.date     = builder.date;
        this.status   = "pending";
    }
 
    public String getUsername() { return username; }
    public String getItemName() { return itemName; }
    public double getAmount()   { return amount; }
    public String getDate()     { return date; }
    public String getStatus()   { return status; }
 
    // ---------------------------------------------------------------
    // BUILDER
    // ---------------------------------------------------------------
    public static class Builder {
 
        private String username;
        private String itemName;
        private double amount;
        private String date;
 
        public Builder username(String username) {
            this.username = username;
            return this;
        }
 
        public Builder itemName(String itemName) {
            this.itemName = itemName;
            return this;
        }
 
        public Builder amount(double amount) {
            this.amount = amount;
            return this;
        }
 
        public Builder date(String date) {
            this.date = date;
            return this;
        }
 
        public Reservation build() {
            if (username == null || username.isEmpty())
                throw new IllegalStateException("Username cannot be empty.");
            if (itemName == null || itemName.isEmpty())
                throw new IllegalStateException("Item name cannot be empty.");
            if (amount <= 0)
                throw new FinanceException("Amount must be greater than zero.", "Reservation.Builder");
            if (date == null || date.isEmpty())
                throw new IllegalStateException("Date cannot be empty.");
            return new Reservation(this);
        }
public abstract class Transaction {
     protected static final double TAX_RATE = 0.12; // 12% VAT
 
    protected final double amount;
    protected final double tax;
    protected final double totalAmount;
    protected final String date;
    protected String status;
 
    protected Transaction(double amount, String date) {
        if (amount <= 0) {
            throw new FinanceException("Amount must be greater than zero.", "Transaction");
        }
        if (date == null || date.isEmpty()) {
            throw new FinanceException("Date cannot be empty.", "Transaction");
        }
        this.amount      = amount;
        this.tax         = applyTax(amount);
        this.totalAmount = amount + this.tax;
        this.date        = date;
        this.status      = "completed";
    }
 
    // Concrete tax method — subclasses inherit this
    protected double applyTax(double amount) {
        return Math.round(amount * TAX_RATE * 100.0) / 100.0;
    }
 
    // Abstract — every subclass must define these
    public abstract String getType();
    public abstract String getDescription();
    public abstract void processTransaction();
 
    // Getters
    public double getAmount()      { return amount; }
    public double getTax()         { return tax; }
    public double getTotalAmount() { return totalAmount; }
    public String getDate()        { return date; }
    public String getStatus()      { return status; }
 
    // Display helper
    public void printSummary() {
        NumberFormat fmt = NumberFormat.getNumberInstance();
        System.out.println("  Type        : " + getType());
        System.out.println("  Description : " + getDescription());
        System.out.println("  Amount      : " + fmt.format(amount));
        System.out.println("  Tax (12%)   : " + fmt.format(tax));
        System.out.println("  Total       : " + fmt.format(totalAmount));
        System.out.println("  Date        : " + date);
        System.out.println("  Status      : " + status);
    }
}